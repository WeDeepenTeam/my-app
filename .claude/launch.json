{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static File Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "3000", "."],
      "port": 3000
    },
    {
      "name": "Tailwind CSS Watch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tailwindcss", "-i", "styles/tailwind.css", "-o", "styles/tailwind.out.css", "--watch"],
      "port": 3001,
      "autoPort": true
    }
  ]
}
